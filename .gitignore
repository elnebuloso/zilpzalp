.idea
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.ruff_cache/
backend/config.yaml

# Lokale Compose-Laufzeitordner (nicht versionieren)
/data/
/config/
/targets/

# Demo: Struktur (.gitkeep), config.yaml und Beispiel-PDF bleiben versioniert,
# der Laufzeit-Output (verschobene/verarbeitete/Fehler-Dateien) nicht.
/demo/data/inbox/*
!/demo/data/inbox/.gitkeep
!/demo/data/inbox/beispiel-rechnung.pdf
/demo/data/error/*
!/demo/data/error/.gitkeep
/demo/data/processed/*
!/demo/data/processed/.gitkeep
/demo/targets/finanzen/*
!/demo/targets/finanzen/.gitkeep
/demo/targets/versicherungen/*
!/demo/targets/versicherungen/.gitkeep
